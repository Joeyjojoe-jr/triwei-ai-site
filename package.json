{
  "name": "triwei-ai-site",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "dev": "bundle exec jekyll serve",
    "build": "bundle exec jekyll build",
    "news:fetch": "python scripts/fetch_news.py",
    "check:news": "python -m py_compile scripts/fetch_news.py && python -m unittest discover -s scripts -p \"test_*.py\"",
    "check:orbit": "node --check assets/js/orbit-navigation.js && node --test scripts/test_orbit_navigation.js"
  }
}
